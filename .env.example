# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# JWT
JWT_SECRET=your-256-bit-secret-at-least-32-chars

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CONNECT_CLIENT_ID=ca_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_STUDIO=price_xxx
STRIPE_PRICE_INDIE_API=price_xxx
STRIPE_PRICE_STUDIO_API=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# Cloudflare
CF_ACCOUNT_ID=your-cf-account-id
CF_API_TOKEN=your-cf-api-token

# Sentry (optional)
SENTRY_DSN_FRONTEND=
SENTRY_DSN_WORKERS=

# Local dev
VITE_API_BASE_URL=https://localhost:8787
VITE_WS_BASE_URL=wss://localhost:8787
