# Local development defaults (safe placeholders)
# Copy to .env for local docker/vite usage: cp .env.dev.example .env

# Supabase local (if using supabase start)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_KEY=local-supabase-service-role-key
SUPABASE_ANON_KEY=local-supabase-anon-key

# JWT
JWT_SECRET=dev-jwt-secret-change-me-32-chars-minimum

# Stripe placeholders (real keys not required if DEV_FAKE_STRIPE=true in apps/workers/.dev.vars)
STRIPE_SECRET_KEY=sk_test_local_placeholder
STRIPE_WEBHOOK_SECRET=whsec_local_placeholder
STRIPE_CONNECT_CLIENT_ID=ca_local_placeholder
STRIPE_PRICE_PRO=price_local_pro
STRIPE_PRICE_STUDIO=price_local_studio
STRIPE_PRICE_INDIE_API=price_local_indie_api
STRIPE_PRICE_STUDIO_API=price_local_studio_api
STRIPE_PRICE_ENTERPRISE=price_local_enterprise

# Cloudflare placeholders for local dev only
CF_ACCOUNT_ID=local-account-id
CF_API_TOKEN=local-api-token

# Local frontend runtime
VITE_API_BASE_URL=https://localhost:8787
VITE_WS_BASE_URL=wss://localhost:8787
